# ─── ROS2 Workspace ───────────────────────────────────────────────────────────
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/
ros2_ws/.colcon_install_layout
colcon.meta

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.egg
.eggs/
pip-wheel-metadata/
*.whl

# ─── Conda / Virtual Envs ─────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
.conda/

# ─── ML Model Weights & Checkpoints ──────────────────────────────────────────
results/gait_cnn.pt
results/gait_rf.pkl
results/*.onnx
results/*.pth
results/*.h5
*.ckpt
*.safetensors

# Keep the plots and screenshots (small, useful for README)
!results/plots/
!results/screenshots/

# ─── Datasets (too large for git) ─────────────────────────────────────────────
data/sample_images/
data/gait/
# Keep the data directory structure
!data/.gitkeep
!data/sample_images/.gitkeep
!data/gait/.gitkeep

# ─── Normalization stats (regenerated by preprocess.py) ──────────────────────
ros2_ws/src/gait_intent/config/norm_mean.npy
ros2_ws/src/gait_intent/config/norm_std.npy

# ─── Gazebo / Simulation Logs ─────────────────────────────────────────────────
*.log
.ros/
~/.gz/
gz_logs/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── C++ Build Artifacts ──────────────────────────────────────────────────────
*.o
*.so
*.a
*.dylib
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake
CTestTestfile.cmake
_CPack_Packages/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
pipeline_run_output.txt

# SAM-VMNet external model + inference outputs
/third_party/
/output/

# ─── ML model artifacts (large binaries; keep out of git) ────────────────────
*.ckpt
*.onnx
*.pt
*.pth
*.pkl
lightning_logs/
results/sam_ckpts/

# Exception: track the final quantized INT8 ONNX model via Git LFS
!results/sam_onnx/vision_encoder.int8.onnx
!results/sam_onnx/prompt_encoder_mask_decoder.int8.onnx
